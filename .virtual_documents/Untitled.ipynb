import pandas as pd
import seaborn as sns
import numpy as np
import matplotlib.pyplot as plt
import warnings

warnings.filterwarnings("ignore")


df=sns.load_dataset("titanic")


df


df.head()


df.isnull().sum()


df.info()


df.columns


df.drop(['deck','embark_town','alive','class','who','adult_male'],inplace=True,axis=1)


df


df.info()


df["age"]=df["age"].fillna(df["age"].mean())


df


df.info()


df.duplicated().sum()


df.shape





df.dropna(subset=["embarked"],inplace=True)


df.info()


df.head()


df["sex"]=df["sex"].replace({"male":1,"female":0})


df["embarked"]=df["embarked"].replace({"Q":1,"C":0,"S":2})


df.head()





# from sklearn.preprocessing import LabelEncoder
