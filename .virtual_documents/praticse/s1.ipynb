df = pd.read_csv("Student_Performance.csv")
df


df.drop_duplicates(inplace=True)


df.duplicated().sum()


df


df.shape


df["Extracurricular Activities"]=df["Extracurricular Activities"].replace({"Yes":0,"No":1})


df


df.isnull().sum()


df.info()


from sklearn.preprocessing import StandardScaler
df2=["Previous Scores"]
scaler=StandardScaler()
df[df2]=scaler.fit_transform(df[df2])



df


from sklearn.preprocessing import StandardScaler
df3=["Hours Studied","Sleep Hours","Sample Question Papers Practiced"]
scaler=StandardScaler()
df[df3]=scaler.fit_transform(df[df3])


df


from sklearn.model_selection import train_test_split


X = df.drop('Performance Index',axis=1)
y = df['Performance Index']


X_train,X_test,y_train,y_test = train_test_split(X,y,test_size=0.20,random_state=42)




from sklearn.linear_model import LinearRegression

model = LinearRegression()
model.fit(X_train,y_train)


y_pred = model.predict(X_test)


y_pred


y_test


from sklearn.metrics import r2_score

r2 = r2_score(y_test, y_pred)
r2



n =  X_test.shape[0]
p = X_test.shape[1]
adjusted_r2 = 1 - ((1-r2)*(n-1)/(n-p-1))
adjusted_r2



